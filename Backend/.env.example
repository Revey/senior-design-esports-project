# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- Database (DigitalOcean Managed Postgres) ---
# Format:   postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
# Example:  postgresql://doadmin:***@db-postgresql-nyc3-1234.b.db.ondigitalocean.com:25060/defaultdb?sslmode=require
DATABASE_URL=

# --- Connection pool (optional) ---
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- Riot Games API ---
# Get your key at: https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Valorant region for match/ranked endpoints (na1, eu, ap, kr, br1, la1, la2)
RIOT_REGION=na1

# Account API region (americas, europe, asia, sea)
RIOT_ACCOUNT_REGION=americas

# --- RSO / Riot Sign-On (optional; only needed for custom-game ingestion) ---
RSO_CLIENT_ID=
RSO_CLIENT_SECRET=
RSO_REDIRECT_URI=http://localhost:8000/api/valorant/rso/callback

# --- Scraping ---
# Seconds to wait between tracker.gg requests (be respectful)
SCRAPE_DELAY=2.0

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Cache ---
# Time-to-live for in-memory cache in seconds
CACHE_TTL=300

# --- CORS / frontend ---
# Comma-separated list of origins allowed by the API. Falls back to
# FRONTEND_ORIGIN + localhost when empty.
ALLOWED_ORIGINS=
FRONTEND_ORIGIN=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=60/minute

# --- Admin ---
# Password used for the /admin login flow; the secret signs the session cookie.
ADMIN_PASSWORD=WillyPilly1964
ADMIN_SECRET=Test
